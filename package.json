{
  "name": "create-bun-mcp",
  "version": "1.0.1",
  "description": "Create a new MCP server project with Bun and TypeScript",
  "author": "Vladimir Kraikovskii (https://github.com/krowten)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krowten/create-bun-mcp.git"
  },
  "homepage": "https://github.com/krowten/create-bun-mcp#readme",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "bun",
    "bun-mcp",
    "typescript",
    "boilerplate",
    "starter-kit",
    "mcp-sdk"
  ],
  "type": "module",
  "bin": {
    "create-bun-mcp": "./bin/index.ts"
  },
  "files": [
    "src",
    "bin",
    "README.md",
    "package.json",
    "tsconfig.json",
    "gitignore.template"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "dev:http": "bun run --watch src/http.ts",
    "start": "bun run src/index.ts",
    "start:http": "bun run src/http.ts",
    "inspect": "bunx @modelcontextprotocol/inspector bun run src/index.ts",
    "inspect:http": "bunx @modelcontextprotocol/inspector",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/inspector": "^0.21.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
